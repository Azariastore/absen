rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──

    // Cek apakah user sudah login sebagai admin
    function isAdmin() {
      return request.auth != null;
    }

    // Cek apakah field yang di-update HANYA field yang diizinkan
    // Dipakai untuk cegah siswa nulis field sembarangan
    function onlyAllowedAbsenFields() {
      let allowed = ['subuh','dhuha','dzuhur','ashar','maghrib','isya','nama','_serverTs'];
      return request.resource.data.keys().hasOnly(allowed);
    }

    // Validasi nilai absen (hanya true atau 'haid')
    function validAbsenValue(val) {
      return val == true || val == 'haid';
    }

    // ── KELAS ──
    match /kelas/{kelasId} {
      allow read: if true;

      // FIX: Hanya admin yang bisa buat/edit/hapus kelas
      allow write: if isAdmin();

      // ── SISWA ──
      match /siswa/{siswaId} {
        allow read: if true;

        // FIX: Pendaftaran diizinkan tapi HANYA field yang valid (cegah inject data aneh)
        allow create: if
          request.resource.data.keys().hasOnly(['nama','gender','phone']) &&
          request.resource.data.nama is string &&
          request.resource.data.nama.size() > 0 &&
          request.resource.data.nama.size() <= 100 &&
          request.resource.data.gender in ['lakiLaki', 'perempuan'];

        // FIX: Hanya admin yang bisa edit/hapus data siswa
        allow update, delete: if isAdmin();
      }
    }

    // ── ABSEN ──
    match /absen/{tanggal}/siswa/{siswaId} {
      allow read: if true;

      // FIX: Create/update absen diizinkan TAPI dibatasi:
      // 1. Hanya field shalat yang valid yang boleh ditulis
      // 2. Nilai harus true atau 'haid' (tidak bisa nulis string sembarangan)
      // Catatan: tanggal tidak kita validasi di rules karena butuh server time
      // (sudah divalidasi di app-level dengan worldtimeapi).
      allow create, update: if
        onlyAllowedAbsenFields() &&
        (
          !('subuh'   in request.resource.data) || validAbsenValue(request.resource.data.subuh) ||
          request.resource.data.subuh == null
        ) &&
        (
          !('dhuha'   in request.resource.data) || validAbsenValue(request.resource.data.dhuha) ||
          request.resource.data.dhuha == null
        ) &&
        (
          !('dzuhur'  in request.resource.data) || validAbsenValue(request.resource.data.dzuhur) ||
          request.resource.data.dzuhur == null
        ) &&
        (
          !('ashar'   in request.resource.data) || validAbsenValue(request.resource.data.ashar) ||
          request.resource.data.ashar == null
        ) &&
        (
          !('maghrib' in request.resource.data) || validAbsenValue(request.resource.data.maghrib) ||
          request.resource.data.maghrib == null
        ) &&
        (
          !('isya'    in request.resource.data) || validAbsenValue(request.resource.data.isya) ||
          request.resource.data.isya == null
        );

      // Hapus absen: hanya admin
      allow delete: if isAdmin();
    }

    // ── STREAK ──
    match /streak/{siswaId} {
      allow read: if true;
      // Streak hanya ditulis oleh app (tidak perlu auth),
      // tapi batasi field yang bisa ditulis
      allow write: if
        request.resource.data.keys().hasOnly(['lastDate','count']) &&
        request.resource.data.count is int &&
        request.resource.data.count >= 0 &&
        request.resource.data.count <= 3650; // max 10 tahun streak
    }

    // ── PRAYER CACHE ──
    match /prayerCache/{docId} {
      allow read: if true;
      // Hanya admin yang bisa set prayer cache (diset manual atau via admin panel)
      allow write: if isAdmin();
    }

    // ── KODE REGISTRASI ──
    match /kodeRegistrasi/{kodeId} {
      allow read: if true;

      // FIX: Siswa boleh UPDATE kode (untuk auto-nonaktifkan kode expired)
      // tapi HANYA field 'aktif' yang boleh diubah, dan hanya bisa di-set ke false
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aktif']) &&
        request.resource.data.aktif == false;

      // Create & delete hanya admin
      allow create, delete: if isAdmin();
    }

    // ── ACTIVITY LOG (jika ada) ──
    match /activityLog/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
